# ============================================================================
#  SETTINGS FILE
#  Copy this file and rename the copy to exactly ".env" (no name, just .env),
#  then fill in the values below. Keep this file PRIVATE - it holds secrets.
# ============================================================================

# Your Claude (Anthropic) API key. Get one at https://console.anthropic.com/settings/keys
# It looks like: sk-ant-api03-...
ANTHROPIC_API_KEY=paste-your-key-here

# The password YOU will type to view the chat logs at /admin.html
# Change this to something only you know.
ADMIN_PASSWORD=change-this-password

# Which Claude model to use. claude-haiku-4-5 is the cheapest and fastest
# (good for a study on a small budget). For higher-quality answers you can use:
#   claude-sonnet-4-6   (mid-tier, more capable)
#   claude-opus-4-8     (most capable, most expensive)
MODEL=claude-haiku-4-5

# Longest reply (in tokens) Claude can give per message. Higher = longer answers
# but slightly more cost. 2048 is a sensible default.
MAX_TOKENS=2048

# Optional: instructions that shape how Claude behaves for every participant.
# Example: "You are a friendly tutor. Keep answers under 100 words."
SYSTEM_PROMPT=You are a helpful assistant.

# The port the site runs on locally. Leave as 3000 unless it's taken.
PORT=3000
